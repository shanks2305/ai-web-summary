# Google Gemini API key (required when provider=gemini)
API_KEY=your-gemini-api-key

# OpenAI API key (required when provider=openai; falls back to API_KEY if unset)
OPENAI_API_KEY=your-openai-api-key

# Server port (default: 3000)
API_PORT=3000

# Log level: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=info

# Optional: path to a custom CA bundle for corporate proxies / TLS issues
# NODE_EXTRA_CA_CERTS=/path/to/ca-bundle.pem

# Optional: disable TLS certificate verification (development only)
# TLS_INSECURE_SKIP_VERIFY=true
